# Kalshi API — required ONLY for the live WebSocket feed.
# Without these the bot still runs, but in REST-only mode (no live Kalshi WS data).
# Create an API key (access key id) + download the RSA private key in your Kalshi
# account settings (Profile -> API Keys).
KALSHI_API_KEY=your_access_key_id
# Path to the RSA private key PEM (or place it at the repo root as kalshi_private_key.pem)
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi_private_key.pem

# Optional: Polymarket WebSocket auth token (only needed for the authenticated user feed)
# POLYMARKET_AUTH_TOKEN=your_token

# Optional: log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
